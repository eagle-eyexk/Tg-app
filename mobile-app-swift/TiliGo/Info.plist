<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
        <key>CFBundleDevelopmentRegion</key>
        <string>$(DEVELOPMENT_LANGUAGE)</string>
        <key>CFBundleDisplayName</key>
        <string>TiliGo</string>
        <key>CFBundleExecutable</key>
        <string>$(EXECUTABLE_NAME)</string>
        <key>CFBundleIdentifier</key>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
        <key>CFBundleInfoDictionaryVersion</key>
        <string>6.0</string>
        <key>CFBundleName</key>
        <string>$(PRODUCT_NAME)</string>
        <key>CFBundlePackageType</key>
        <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
        <key>CFBundleShortVersionString</key>
        <string>$(MARKETING_VERSION)</string>
        <key>CFBundleVersion</key>
        <string>$(CURRENT_PROJECT_VERSION)</string>
        <key>LSRequiresIPhoneOS</key>
        <true/>
        <key>UILaunchScreen</key>
        <dict>
                <key>UIColorName</key>
                <string>LaunchBackground</string>
        </dict>
        <key>UIRequiredDeviceCapabilities</key>
        <array>
                <string>arm64</string>
        </array>
        <key>UISupportedInterfaceOrientations</key>
        <array>
                <string>UIInterfaceOrientationPortrait</string>
                <string>UIInterfaceOrientationLandscapeLeft</string>
                <string>UIInterfaceOrientationLandscapeRight</string>
        </array>
        <key>UISupportedInterfaceOrientations~ipad</key>
        <array>
                <string>UIInterfaceOrientationPortrait</string>
                <string>UIInterfaceOrientationPortraitUpsideDown</string>
                <string>UIInterfaceOrientationLandscapeLeft</string>
                <string>UIInterfaceOrientationLandscapeRight</string>
        </array>
        <key>NSAppTransportSecurity</key>
        <dict>
                <key>NSAllowsArbitraryLoads</key>
                <false/>
                <key>NSExceptionDomains</key>
                <dict>
                        <key>tiligo-delivery-flow.base44.app</key>
                        <dict>
                                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                                <false/>
                                <key>NSIncludesSubdomains</key>
                                <true/>
                        </dict>
                        <key>base44.app</key>
                        <dict>
                                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                                <false/>
                                <key>NSIncludesSubdomains</key>
                                <true/>
                        </dict>
                </dict>
        </dict>
        <key>UIStatusBarStyle</key>
        <string>UIStatusBarStyleDefault</string>
        <key>UIViewControllerBasedStatusBarAppearance</key>
        <true/>
        <key>NSCameraUsageDescription</key>
        <string>TiliGo needs access to your camera for delivery photo uploads</string>
        <key>NSLocationWhenInUseUsageDescription</key>
        <string>TiliGo needs access to your location for real-time delivery tracking</string>
        <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
        <string>TiliGo needs access to your location for real-time delivery tracking</string>
        <key>NSPhotoLibraryUsageDescription</key>
        <string>TiliGo needs access to your photo library for uploading images</string>
        <key>NSPhotoLibraryAddOnlyUsageDescription</key>
        <string>TiliGo needs permission to save photos to your library</string>
        <key>NSMicrophoneUsageDescription</key>
        <string>TiliGo may need access to your microphone for messaging features</string>
        <key>NSContactsUsageDescription</key>
        <string>TiliGo needs access to your contacts for sharing delivery details</string>
        <key>CFBundleURLTypes</key>
        <array>
                <dict>
                        <key>CFBundleURLName</key>
                        <string>com.tiligo.app</string>
                        <key>CFBundleURLSchemes</key>
                        <array>
                                <string>tiligo</string>
                        </array>
                </dict>
        </array>
        <key>NSLocalNetworkUsageDescription</key>
        <string>TiliGo needs to discover local network devices for communication</string>
</dict>
</plist>
